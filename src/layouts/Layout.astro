---
import '../styles/global.css';
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="진짜 맛있는 한 끼, 맛집맵" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-gray-50 min-h-screen">
    <slot />
    <script is:inline>
      window.naverMapReady = function() {
        window.dispatchEvent(new Event('naverMapReady'));
      };
    </script>
    <script src="https://openapi.map.naver.com/openapi/v3/maps.js?ncpClientId=1yjshszp92&callback=naverMapReady" defer></script>
  </body>
</html>
