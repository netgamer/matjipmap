---
import Layout from '../layouts/Layout.astro';
import Map from '../components/Map.astro';
import { getCollection } from 'astro:content';

const places = await getCollection('places');

const categories = ['all', 'korean', 'japanese', 'chinese', 'western', 'bunsik', 'cafe'];
const categoryCounts = {
  all: places.length,
  korean: places.filter(p => p.data.category === 'korean').length,
  japanese: places.filter(p => p.data.category === 'japanese').length,
  chinese: places.filter(p => p.data.category === 'chinese').length,
  western: places.filter(p => p.data.category === 'western').length,
  bunsik: places.filter(p => p.data.category === 'bunsik').length,
  cafe: places.filter(p => p.data.category === 'cafe').length,
};

const categoryLabels = {
  all: '전체',
  korean: '한식',
  japanese: '일식',
  chinese: '중식',
  western: '양식',
  bunsik: '분식',
  cafe: '카페',
};

function getDisplayImage(url?: string): string | undefined {
  if (!url) return undefined;
  if (url.includes('images.unsplash.com') || url.includes('loremflickr.com')) {
    return undefined;
  }
  return url;
}
---

<Layout title="맛집맵 - 진짜 맛있는 한 끼">
  <header class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
      <h1 class="text-lg lg:text-xl font-bold text-orange-600 flex items-center gap-2">
        <span>🍽️</span>
        <a href="/" class="flex flex-wrap items-center gap-1">
          <span class="hidden lg:inline">거지맵의 대항마</span>
          <span>맛집맵!</span>
          <span class="hidden lg:inline text-sm font-normal text-gray-600">| 한번먹어도 찐 맛집만 간다</span>
        </a>
      </h1>
      <nav class="flex gap-4">
        <a href="/" class="text-orange-600 font-medium">로컬 맛집</a>
        <a href="/hall-of-fame" class="text-gray-600 hover:text-orange-600">명예의 전당</a>
        <a href="/register" class="text-gray-600 hover:text-orange-600">맛집 등록</a>
      </nav>
    </div>
  </header>

  <div class="bg-gradient-to-r from-orange-500 to-red-500 text-white px-4 py-2">
    <p class="text-center text-sm font-medium">🏆 나만 아는 찐 맛집! 로컬 인증을 받은 맛집만 모였습니다</p>
  </div>

  <div class="bg-white border-b border-gray-200 px-4 py-2 overflow-x-auto">
    <div class="flex gap-2 min-w-max" id="category-filters">
      {categories.map((cat) => (
        <button 
          class="filter-btn px-3 py-1 rounded-full text-sm font-medium whitespace-nowrap border border-gray-300" 
          data-category={cat}
        >
          {categoryLabels[cat]} <span class="text-xs opacity-70">({categoryCounts[cat]})</span>
        </button>
      ))}
    </div>
  </div>

  <main class="flex flex-col lg:flex-row" style="height: calc(100vh - 125px);">
    <div class="w-full lg:flex-1 h-[50vh] lg:h-full relative">
      <Map places={places} />
    </div>
    
    <aside class="w-full lg:w-96 bg-white border-t lg:border-t-0 lg:border-l border-gray-200 overflow-y-auto lg:h-full">
      <div class="p-4 border-b border-gray-200 sticky top-0 bg-white">
        <h2 class="font-semibold text-gray-800">🏡 로컬 찐 맛집</h2>
        <p class="text-sm text-gray-500" id="place-count">{places.length}개 맛집</p>
      </div>
      <div class="p-4 space-y-4" id="place-list">
        {places.map((place) => {
          const isEliminated = place.data.status === 'eliminated';
          const imageUrl = getDisplayImage(place.data.imageUrl);
          return (
          <a 
            href={`/place/${place.id}`} 
            class={`block bg-white border rounded-lg overflow-hidden hover:shadow-md transition group ${isEliminated ? 'border-gray-300 opacity-60' : 'border-gray-200 hover:border-orange-300'}`}
            data-category={place.data.category}
          >
            <div class="flex">
              <div class="w-24 h-24 flex-shrink-0 bg-gray-100">
                {imageUrl ? (
                  <img 
                    src={imageUrl} 
                    alt={place.data.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-orange-50 to-amber-100 text-[11px] text-center text-gray-500 px-2">
                    실사진 준비 중
                  </div>
                )}
              </div>
              <div class="flex-1 p-3">
                <div class="flex justify-between items-start mb-1">
                  <div>
                    <h3 class={`font-semibold text-sm group-hover:text-orange-600 ${isEliminated ? 'text-gray-500 line-through' : 'text-gray-900'}`}>
                      {place.data.name}
                    </h3>
                  </div>
                  {isEliminated ? (
                    <span class="px-1.5 py-0.5 rounded text-xs font-medium bg-gray-200 text-gray-500">
                      탈락
                    </span>
                  ) : (
                    <span class="px-1.5 py-0.5 rounded text-xs font-medium bg-orange-100 text-orange-700">
                      찐맛집
                    </span>
                  )}
                </div>
                
                <p class="text-xs text-gray-500 mb-2 truncate">{place.data.address}</p>
                
                <div class="flex items-center justify-between">
                  <span class="text-xs px-1.5 py-0.5 bg-gray-100 text-gray-600 rounded">
                    {categoryLabels[place.data.category]}
                  </span>
                  {place.data.rating && (
                    <div class="flex items-center gap-1">
                      <span class={place.data.rating < 3 ? 'text-gray-400' : 'text-yellow-500'}>★</span>
                      <span class={`text-xs font-medium ${place.data.rating < 3 ? 'text-gray-400' : ''}`}>{place.data.rating.toFixed(1)}</span>
                    </div>
                  )}
                </div>
                
                {place.data.menus && place.data.menus.length > 0 && (
                  <p class="text-xs text-gray-400 mt-1 truncate">
                    {place.data.menus[0].name}
                  </p>
                )}
              </div>
            </div>
          </a>
          );
        })}
      </div>
    </aside>
  </main>
</Layout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const placeList = document.getElementById('place-list');
  const placeCount = document.getElementById('place-count');
  
  filterBtns[0].classList.add('bg-orange-100', 'text-orange-700');
  
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category;
      
      filterBtns.forEach(b => b.classList.remove('bg-orange-100', 'text-orange-700'));
      btn.classList.add('bg-orange-100', 'text-orange-700');
      
      const cards = placeList.querySelectorAll('a[data-category]');
      let visibleCount = 0;
      
      cards.forEach(card => {
        const cardCategory = card.getAttribute('data-category');
        if (category === 'all' || cardCategory === category) {
          (card as HTMLElement).style.display = 'block';
          visibleCount++;
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
      
      placeCount.textContent = `${visibleCount}개 맛집`;
    });
  });
</script>
