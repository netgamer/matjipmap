---
import Layout from '../layouts/Layout.astro';
import Map from '../components/Map.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { getCollection } from 'astro:content';
import { dedupePlaces, getDisplayImageUrl } from '../lib/place-utils';

const rawPlaces = await getCollection('places');
const places = dedupePlaces(rawPlaces);

const categories = ['all', 'korean', 'japanese', 'chinese', 'western', 'bunsik', 'cafe'] as const;
const categoryCounts = {
  all: places.length,
  korean: places.filter((p) => p.data.category === 'korean').length,
  japanese: places.filter((p) => p.data.category === 'japanese').length,
  chinese: places.filter((p) => p.data.category === 'chinese').length,
  western: places.filter((p) => p.data.category === 'western').length,
  bunsik: places.filter((p) => p.data.category === 'bunsik').length,
  cafe: places.filter((p) => p.data.category === 'cafe').length,
};

const categoryLabels = {
  all: '전체',
  korean: '한식',
  japanese: '일식',
  chinese: '중식',
  western: '양식',
  bunsik: '분식',
  cafe: '카페',
};

---

<Layout
  title="맛집맵 | 진짜 사진으로 찾는 로컬 맛집 지도"
  description="맛집맵은 실제 사진과 방문 경험을 바탕으로 동네 맛집을 찾는 로컬 맛집 지도입니다. 한식, 일식, 중식, 카페까지 한눈에 찾을 수 있습니다."
>
  <div class="mm-shell">
    <SiteHeader active="list" />

  <section class="border-b border-gray-200 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-10 lg:py-16">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.28em] text-orange-600">Local restaurant map</p>
      <div class="max-w-4xl">
        <h1 class="text-4xl font-semibold tracking-tight text-gray-950 sm:text-5xl lg:text-7xl">
          맛집맵
        </h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-gray-600 sm:text-lg">
          실제 사진과 방문 경험을 바탕으로, 다시 가고 싶은 로컬 맛집만 모아둔 지도입니다.
        </p>
        <div class="mt-8 flex flex-wrap gap-3 text-sm text-gray-600">
          <span class="rounded-full border border-gray-200 bg-gray-50 px-4 py-2">
            등록된 맛집 {places.length}곳
          </span>
          <span class="rounded-full border border-gray-200 bg-gray-50 px-4 py-2">
            실제 사진 기반 큐레이션
          </span>
        </div>
      </div>
    </div>
  </section>

  <div class="border-b border-gray-200 bg-white px-4 py-3 overflow-x-auto">
    <div class="mx-auto flex max-w-7xl gap-2 min-w-max" id="category-filters">
      {categories.map((cat) => (
        <button
          class="filter-btn rounded-full border border-gray-300 px-3 py-1 text-sm font-medium whitespace-nowrap text-gray-700 transition hover:border-gray-900 hover:text-gray-950"
          data-category={cat}
        >
          {categoryLabels[cat]} <span class="text-xs opacity-60">({categoryCounts[cat]})</span>
        </button>
      ))}
    </div>
  </div>

  <main class="mx-auto max-w-[1600px] px-4 py-6 lg:grid lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] lg:gap-6 lg:py-8">
    <aside class="order-2 w-full bg-white lg:order-1">
      <div class="border-b border-gray-200 bg-white px-1 pb-4">
        <h2 class="text-base font-semibold text-gray-950">등록된 맛집</h2>
        <p class="mt-1 text-sm text-gray-500" id="place-count">
          {places.length}곳
        </p>
      </div>
      <div class="space-y-4 pt-4" id="place-list">
        {places.map((place) => {
          const isEliminated = place.data.status === 'eliminated';
          const imageUrl = getDisplayImageUrl(place.data.imageUrl);

          return (
            <a
              href={`/place/${place.id}`}
              class={`group block overflow-hidden rounded-2xl border bg-white transition hover:shadow-md ${
                isEliminated
                  ? 'border-gray-200 opacity-60'
                  : 'border-gray-200 hover:border-orange-300'
              }`}
              data-category={place.data.category}
            >
              <div class="flex">
                <div class="relative h-28 w-28 flex-shrink-0 bg-gray-100">
                  {imageUrl ? (
                    <>
                      <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-orange-50 to-amber-100 px-3 text-center text-[11px] text-gray-500">
                        ?ъ쭊 以鍮?以?
                      </div>
                      <img
                        src={imageUrl}
                        alt={place.data.name}
                        class="relative z-10 h-full w-full object-cover"
                        loading="lazy"
                        decoding="async"
                        onerror="this.style.display='none'"
                      />
                    </>
                  ) : (
                    <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-orange-50 to-amber-100 px-3 text-center text-[11px] text-gray-500">
                      사진 준비 중
                    </div>
                  )}
                </div>

                <div class="flex-1 p-4">
                  <div class="mb-2 flex items-start justify-between gap-3">
                    <div>
                      <h3
                        class={`text-sm font-semibold transition group-hover:text-orange-600 ${
                          isEliminated ? 'text-gray-500 line-through' : 'text-gray-900'
                        }`}
                      >
                        {place.data.name}
                      </h3>
                    </div>
                    <span
                      class={`rounded-full px-2 py-1 text-xs font-medium ${
                        isEliminated
                          ? 'bg-gray-100 text-gray-500'
                          : 'bg-orange-50 text-orange-700'
                      }`}
                    >
                      {isEliminated ? '탈락' : '찐맛집'}
                    </span>
                  </div>

                  <p class="mb-3 truncate text-xs text-gray-500">{place.data.address}</p>

                  <div class="flex items-center justify-between">
                    <span class="rounded-full bg-gray-100 px-2 py-1 text-xs text-gray-600">
                      {categoryLabels[place.data.category]}
                    </span>
                    {place.data.rating && (
                      <div class="flex items-center gap-1 text-xs font-medium text-gray-700">
                        <span class={place.data.rating < 3 ? 'text-gray-300' : 'text-yellow-500'}>★</span>
                        <span>{place.data.rating.toFixed(1)}</span>
                      </div>
                    )}
                  </div>

                  {place.data.menus && place.data.menus.length > 0 && (
                    <p class="mt-2 truncate text-xs text-gray-400">{place.data.menus[0].name}</p>
                  )}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </aside>

    <div class="order-1 w-full lg:order-2">
      <div class="border border-gray-200 bg-white lg:sticky lg:top-[7.5rem] lg:h-[calc(100vh-9rem)]">
        <div class="relative h-[48vh] min-h-[420px] w-full lg:h-full">
          <Map places={places} />
        </div>
      </div>
    </div>
  </main>
  </div>
</Layout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const placeList = document.getElementById('place-list');
  const placeCount = document.getElementById('place-count');

  filterBtns[0]?.classList.add('bg-gray-950', 'text-white', 'border-gray-950');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category;

      filterBtns.forEach((button) => {
        button.classList.remove('bg-gray-950', 'text-white', 'border-gray-950');
      });
      btn.classList.add('bg-gray-950', 'text-white', 'border-gray-950');

      const cards = placeList?.querySelectorAll('a[data-category]') ?? [];
      let visibleCount = 0;

      cards.forEach((card) => {
        const cardCategory = card.getAttribute('data-category');
        if (category === 'all' || cardCategory === category) {
          (card as HTMLElement).style.display = 'block';
          visibleCount += 1;
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });

      if (placeCount) {
        placeCount.textContent = `${visibleCount}곳`;
      }
    });
  });
</script>
