---
import Layout from '../layouts/Layout.astro';
---

<Layout title="맛집 등록하기 - 맛집맵">
  <header class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="text-xl font-bold text-orange-600 flex items-center gap-2">
        <span>🍽️</span>
        맛집맵
      </a>
      <nav class="flex items-center gap-4">
        <a href="/" class="text-gray-600 hover:text-orange-600">맛집 목록</a>
        <a href="/hall-of-fame" class="text-gray-600 hover:text-orange-600">명예의 전당</a>
        <a href="/register" class="text-orange-600 font-medium">맛집 등록</a>
      </nav>
    </div>
  </header>

  <main class="max-w-2xl mx-auto px-4 py-8">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">맛집 등록하기</h1>
      <p class="text-gray-600">나만의 찐 맛집을 추천하세요!</p>
    </div>
    
    <div class="bg-gradient-to-r from-orange-50 to-red-50 rounded-xl p-4 mb-6 text-sm">
      <p class="text-gray-600">
        * 등록된 맛집은 별점에 따라 순위가 매겨지며, <span class="text-red-600 font-medium">별점이 낮으면 탈락</span>할 수 있습니다.
      </p>
    </div>
    
    <form id="registerForm" class="bg-white rounded-xl shadow-sm p-6 space-y-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">가게명 *</label>
        <input 
          type="text" 
          name="name"
          required
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500"
          placeholder="맛집 이름을 입력하세요"
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">주소 *</label>
        <input 
          type="text" 
          name="address"
          required
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500"
          placeholder="주소를 입력하세요"
        />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">위도</label>
          <input 
            type="number" 
            name="lat"
            step="0.000001"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500"
            placeholder="37.5665"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">경도</label>
          <input 
            type="number" 
            name="lng"
            step="0.000001"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500"
            placeholder="126.9780"
          />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">음식 카테고리 *</label>
        <select 
          name="category"
          required
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500"
        >
          <option value="korean">한식</option>
          <option value="japanese">일식</option>
          <option value="chinese">중식</option>
          <option value="western">양식</option>
          <option value="bunsik">분식</option>
          <option value="cafe">카페</option>
          <option value="other">기타</option>
        </select>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">대표 메뉴 *</label>
          <input 
            type="text" 
            name="menuName"
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500"
            placeholder="메뉴명"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">가격 *</label>
          <input 
            type="number" 
            name="menuPrice"
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500"
            placeholder="12000"
          />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">한 줄 추천 (선택)</label>
        <input 
          type="text" 
          name="description"
          maxLength="100"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500"
          placeholder="이 가게의 매력을 한 문장으로!"
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">전화번호 (선택)</label>
        <input 
          type="tel" 
          name="phone"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500"
          placeholder="02-1234-5678"
        />
      </div>

      <button 
        type="submit"
        class="w-full bg-gradient-to-r from-orange-500 to-red-500 text-white py-3 px-4 rounded-lg font-medium hover:opacity-90 transition"
      >
        맛집 등록하기
      </button>
    </form>

    <div id="successMessage" class="hidden mt-6 bg-green-50 border border-green-200 rounded-xl p-6 text-center">
      <p class="text-green-600 font-medium mb-2">맛집이 등록되었습니다!</p>
      <p class="text-sm text-gray-600">다른 사용자들과 함께 찐 맛집을 만들어 가세요.</p>
      <a href="/" class="inline-block mt-4 px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600">
        맛집 목록 보기
      </a>
    </div>

    <div class="mt-8 bg-gray-50 rounded-xl p-6">
      <h3 class="font-bold text-gray-800 mb-3">탈락 기준 안내</h3>
      <ul class="text-sm text-gray-600 space-y-2">
        <li>* 평균 별점이 <span class="text-red-600 font-medium">3.0 미만</span>이면 탈락</li>
        <li>* 리뷰가 5개 이상 달렸을 때 평균 별점이 반영됩니다</li>
        <li>* 탈락한 맛집은 명예의 전당에서 제외됩니다</li>
        <li>* 맛집 탈락은 복원될 수 있습니다 (평균 별점 4.0 이상 시)</li>
      </ul>
    </div>
  </main>
</Layout>

<script>
  document.getElementById('registerForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);
    
    const data = {
      name: formData.get('name'),
      address: formData.get('address'),
      lat: formData.get('lat') || 37.5 + (Math.random() * 0.2 - 0.1),
      lng: formData.get('lng') || 126.9 + (Math.random() * 0.2 - 0.1),
      category: formData.get('category'),
      menuName: formData.get('menuName'),
      menuPrice: formData.get('menuPrice'),
      description: formData.get('description') || '나만의 찐 맛집이에요!',
      phone: formData.get('phone'),
    };
    
    const places = JSON.parse(localStorage.getItem('user_places') || '[]');
    const newPlace = {
      id: `user_${Date.now()}`,
      ...data,
      rating: 0,
      reviewCount: 0,
      status: 'pending',
      createdAt: new Date().toISOString(),
      reviews: [],
    };
    
    places.push(newPlace);
    localStorage.setItem('user_places', JSON.stringify(places));
    
    form.classList.add('hidden');
    document.getElementById('successMessage')?.classList.remove('hidden');
  });
</script>
