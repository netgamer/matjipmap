---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Layout title="맛집 등록하기 - 맛집맵">
  <div class="mm-shell">
  <SiteHeader active="register" />

  <main class="text-black">
    <section class="mx-auto grid max-w-6xl gap-16 px-5 py-14 sm:px-8 lg:grid-cols-[1.05fr_0.95fr] lg:gap-20 lg:py-24">
      <div class="space-y-10">
        <div class="space-y-6">
          <p class="text-[11px] font-medium uppercase tracking-[0.28em] text-orange-600">Submit A Place</p>
          <h1 class="max-w-3xl text-5xl font-semibold leading-[0.92] tracking-[-0.06em] text-balance sm:text-6xl lg:text-7xl">
            큰 글씨보다 먼저 보이는 건
            <br />
            정확한 위치입니다.
          </h1>
          <p class="max-w-2xl text-base leading-7 text-black/62 sm:text-lg">
            검증 가능한 주소와 좌표, 대표 메뉴만 남깁니다. 대충 등록하는 대신, 실제로 다시 찾을 수 있는 맛집 데이터로 쌓습니다.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div class="rounded-3xl border border-black/10 bg-white px-5 py-5">
            <p class="text-[11px] uppercase tracking-[0.22em] text-black/42">01</p>
            <p class="mt-6 text-lg font-medium tracking-[-0.03em]">위치를 직접 선택</p>
            <p class="mt-2 text-sm leading-6 text-black/55">지도에서 클릭한 좌표가 바로 등록 폼에 반영됩니다.</p>
          </div>
          <div class="rounded-3xl border border-black/10 bg-white px-5 py-5">
            <p class="text-[11px] uppercase tracking-[0.22em] text-black/42">02</p>
            <p class="mt-6 text-lg font-medium tracking-[-0.03em]">필수 정보만 입력</p>
            <p class="mt-2 text-sm leading-6 text-black/55">가게명, 주소, 메뉴와 가격만 있으면 등록 흐름이 끝납니다.</p>
          </div>
          <div class="rounded-3xl border border-black/10 bg-white px-5 py-5">
            <p class="text-[11px] uppercase tracking-[0.22em] text-black/42">03</p>
            <p class="mt-6 text-lg font-medium tracking-[-0.03em]">낮은 별점은 탈락</p>
            <p class="mt-2 text-sm leading-6 text-black/55">등록된 맛집은 사용자 평가를 통과해야 계속 남습니다.</p>
          </div>
        </div>

        <div class="rounded-[2rem] border border-black/10 bg-black px-6 py-7 text-white sm:px-8">
          <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="text-[11px] uppercase tracking-[0.22em] text-white/55">Quality Bar</p>
              <p class="mt-4 max-w-xl text-2xl font-medium tracking-[-0.04em]">
                등록된 맛집은 별점이 낮으면 정리됩니다.
              </p>
            </div>
            <p class="max-w-sm text-sm leading-6 text-white/68">
              리뷰 5개 이상에서 평균 별점이 반영되고, 3.0 미만은 탈락 대상으로 분류됩니다.
            </p>
          </div>
        </div>
      </div>

      <div class="lg:pt-6">
        <form id="registerForm" class="rounded-[2rem] border border-black/10 bg-white p-6 shadow-[0_24px_80px_rgba(0,0,0,0.06)] sm:p-8">
          <div class="mb-10 flex items-start justify-between gap-4">
            <div>
              <p class="text-[11px] uppercase tracking-[0.22em] text-black/45">Register</p>
              <h2 class="mt-3 text-3xl font-semibold tracking-[-0.05em]">맛집 등록</h2>
            </div>
            <span class="rounded-full border border-orange-200 bg-orange-50 px-3 py-1 text-xs font-medium text-orange-700">
              위치 필수 검증
            </span>
          </div>

          <div class="space-y-8">
            <div class="space-y-2">
              <label class="text-xs font-medium uppercase tracking-[0.2em] text-black/46">가게명</label>
              <input
                type="text"
                name="name"
                required
                class="w-full rounded-2xl border border-black/12 bg-[#fbfbfb] px-4 py-4 text-[15px] outline-none transition placeholder:text-black/28 focus:border-orange-500 focus:bg-white"
                placeholder="맛집 이름을 입력하세요"
              />
            </div>

            <div class="space-y-2">
              <label class="text-xs font-medium uppercase tracking-[0.2em] text-black/46">주소</label>
              <input
                type="text"
                name="address"
                required
                class="w-full rounded-2xl border border-black/12 bg-[#fbfbfb] px-4 py-4 text-[15px] outline-none transition placeholder:text-black/28 focus:border-orange-500 focus:bg-white"
                placeholder="주소를 입력하세요"
              />
            </div>

            <section class="rounded-[1.5rem] border border-black/10 bg-[#fafafa] p-5 sm:p-6">
              <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <p class="text-xs font-medium uppercase tracking-[0.2em] text-black/46">Location Picker</p>
                  <h3 class="mt-3 text-2xl font-semibold tracking-[-0.04em]">지도를 열고 위치를 찍으세요.</h3>
                  <p class="mt-3 max-w-md text-sm leading-6 text-black/55">
                    좌표를 직접 입력할 수도 있지만, 지도에서 선택하면 실수 없이 바로 채워집니다.
                  </p>
                </div>
                <div class="flex gap-2">
                  <button
                    type="button"
                    id="toggleLocationPicker"
                    class="rounded-full bg-orange-500 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-orange-600"
                  >
                    위치선택
                  </button>
                  <button
                    type="button"
                    id="useCurrentLocation"
                    class="rounded-full border border-black/12 bg-white px-4 py-2.5 text-sm font-medium text-black transition hover:border-black/20 hover:bg-black/[0.03]"
                  >
                    현재 위치
                  </button>
                </div>
              </div>

              <div id="locationPickerPanel" class="mt-6 hidden">
                <div class="mb-3 flex items-center justify-between gap-4">
                  <p id="locationPickerHelp" class="text-sm text-black/52">지도에서 위치를 클릭하세요.</p>
                  <button
                    type="button"
                    id="closeLocationPicker"
                    class="text-xs font-medium uppercase tracking-[0.18em] text-black/45 transition hover:text-black"
                  >
                    닫기
                  </button>
                </div>
                <div id="registerMap" class="h-80 overflow-hidden rounded-[1.5rem] border border-black/10 bg-white"></div>
              </div>
            </section>

            <div class="grid gap-4 sm:grid-cols-2">
              <div class="space-y-2">
                <label class="text-xs font-medium uppercase tracking-[0.2em] text-black/46">위도</label>
                <input
                  type="number"
                  name="lat"
                  step="0.000001"
                  class="w-full rounded-2xl border border-black/12 bg-[#fbfbfb] px-4 py-4 text-[15px] outline-none transition placeholder:text-black/28 focus:border-orange-500 focus:bg-white"
                  placeholder="37.5665"
                />
              </div>
              <div class="space-y-2">
                <label class="text-xs font-medium uppercase tracking-[0.2em] text-black/46">경도</label>
                <input
                  type="number"
                  name="lng"
                  step="0.000001"
                  class="w-full rounded-2xl border border-black/12 bg-[#fbfbfb] px-4 py-4 text-[15px] outline-none transition placeholder:text-black/28 focus:border-orange-500 focus:bg-white"
                  placeholder="126.9780"
                />
              </div>
            </div>

            <div class="space-y-2">
              <label class="text-xs font-medium uppercase tracking-[0.2em] text-black/46">음식 카테고리</label>
              <select
                name="category"
                required
                class="w-full rounded-2xl border border-black/12 bg-[#fbfbfb] px-4 py-4 text-[15px] outline-none transition focus:border-orange-500 focus:bg-white"
              >
                <option value="korean">한식</option>
                <option value="japanese">일식</option>
                <option value="chinese">중식</option>
                <option value="western">양식</option>
                <option value="bunsik">분식</option>
                <option value="cafe">카페</option>
                <option value="other">기타</option>
              </select>
            </div>

            <div class="grid gap-4 sm:grid-cols-[1.2fr_0.8fr]">
              <div class="space-y-2">
                <label class="text-xs font-medium uppercase tracking-[0.2em] text-black/46">대표 메뉴</label>
                <input
                  type="text"
                  name="menuName"
                  required
                  class="w-full rounded-2xl border border-black/12 bg-[#fbfbfb] px-4 py-4 text-[15px] outline-none transition placeholder:text-black/28 focus:border-orange-500 focus:bg-white"
                  placeholder="메뉴명"
                />
              </div>
              <div class="space-y-2">
                <label class="text-xs font-medium uppercase tracking-[0.2em] text-black/46">가격</label>
                <input
                  type="number"
                  name="menuPrice"
                  required
                  class="w-full rounded-2xl border border-black/12 bg-[#fbfbfb] px-4 py-4 text-[15px] outline-none transition placeholder:text-black/28 focus:border-orange-500 focus:bg-white"
                  placeholder="12000"
                />
              </div>
            </div>

            <div class="space-y-2">
              <label class="text-xs font-medium uppercase tracking-[0.2em] text-black/46">한 줄 추천</label>
              <input
                type="text"
                name="description"
                maxLength="100"
                class="w-full rounded-2xl border border-black/12 bg-[#fbfbfb] px-4 py-4 text-[15px] outline-none transition placeholder:text-black/28 focus:border-orange-500 focus:bg-white"
                placeholder="이 가게의 매력을 한 문장으로!"
              />
            </div>

            <div class="space-y-2">
              <label class="text-xs font-medium uppercase tracking-[0.2em] text-black/46">전화번호</label>
              <input
                type="tel"
                name="phone"
                class="w-full rounded-2xl border border-black/12 bg-[#fbfbfb] px-4 py-4 text-[15px] outline-none transition placeholder:text-black/28 focus:border-orange-500 focus:bg-white"
                placeholder="02-1234-5678"
              />
            </div>

            <div class="flex flex-col gap-4 border-t border-black/8 pt-6">
              <button
                type="submit"
                class="inline-flex items-center justify-center rounded-full bg-black px-5 py-4 text-sm font-medium text-white transition hover:bg-orange-500"
              >
                맛집 등록하기
              </button>
              <p class="text-sm leading-6 text-black/48">
                등록 후에는 로컬 저장소에 보관되고, 리뷰가 쌓이면 순위에 반영됩니다.
              </p>
            </div>
          </div>
        </form>

        <div id="successMessage" class="mt-8 hidden rounded-[2rem] border border-orange-200 bg-orange-50 p-8">
          <p class="text-[11px] font-medium uppercase tracking-[0.22em] text-orange-700">Saved</p>
          <p class="mt-4 text-3xl font-semibold tracking-[-0.05em] text-black">맛집이 등록되었습니다.</p>
          <p class="mt-3 max-w-lg text-sm leading-6 text-black/58">
            지금 등록한 데이터는 로컬에 저장되었습니다. 다음 단계는 실제 사진과 리뷰가 쌓이는 것입니다.
          </p>
          <a
            href="/"
            class="mt-8 inline-flex rounded-full bg-black px-5 py-3 text-sm font-medium text-white transition hover:bg-orange-500"
          >
            맛집 목록 보기
          </a>
        </div>
      </div>
    </section>
  </main>
  </div>
</Layout>

<script>
  const form = document.getElementById('registerForm') as HTMLFormElement | null;
  const latInput = form?.elements.namedItem('lat') as HTMLInputElement | null;
  const lngInput = form?.elements.namedItem('lng') as HTMLInputElement | null;
  const toggleLocationPickerButton = document.getElementById('toggleLocationPicker');
  const closeLocationPickerButton = document.getElementById('closeLocationPicker');
  const useCurrentLocationButton = document.getElementById('useCurrentLocation');
  const locationPickerPanel = document.getElementById('locationPickerPanel');
  const locationPickerHelp = document.getElementById('locationPickerHelp');

  let registerMap: any;
  let registerMarker: any;

  function setPickedLocation(lat: number, lng: number, moveMap = true) {
    if (!latInput || !lngInput) return;

    latInput.value = lat.toFixed(6);
    lngInput.value = lng.toFixed(6);

    if (registerMap && typeof naver !== 'undefined') {
      const position = new naver.maps.LatLng(lat, lng);
      if (!registerMarker) {
        registerMarker = new naver.maps.Marker({
          position,
          map: registerMap,
        });
      } else {
        registerMarker.setPosition(position);
      }

      if (moveMap) {
        registerMap.setCenter(position);
      }
    }

    if (locationPickerHelp) {
      locationPickerHelp.textContent = `선택된 위치: ${lat.toFixed(6)}, ${lng.toFixed(6)}`;
    }
  }

  function initRegisterMap() {
    if (registerMap || !locationPickerPanel) return;

    if (typeof naver === 'undefined') {
      setTimeout(initRegisterMap, 100);
      return;
    }

    const defaultLat = latInput?.value ? Number(latInput.value) : 37.5666805;
    const defaultLng = lngInput?.value ? Number(lngInput.value) : 126.9784147;
    const defaultPosition = new naver.maps.LatLng(defaultLat, defaultLng);

    registerMap = new naver.maps.Map('registerMap', {
      center: defaultPosition,
      zoom: 14,
      mapDataControl: false,
      scaleControl: false,
    });

    if (latInput?.value && lngInput?.value) {
      setPickedLocation(defaultLat, defaultLng, false);
    }

    naver.maps.Event.addListener(registerMap, 'click', (event: any) => {
      setPickedLocation(event.coord.lat(), event.coord.lng(), false);
    });
  }

  function openLocationPicker() {
    if (!locationPickerPanel) return;
    locationPickerPanel.classList.remove('hidden');
    initRegisterMap();
    setTimeout(() => {
      if (registerMap) {
        naver.maps.Event.trigger(registerMap, 'resize');
      }
    }, 0);
  }

  function closeLocationPicker() {
    locationPickerPanel?.classList.add('hidden');
  }

  toggleLocationPickerButton?.addEventListener('click', () => {
    if (locationPickerPanel?.classList.contains('hidden')) {
      openLocationPicker();
    } else {
      closeLocationPicker();
    }
  });

  closeLocationPickerButton?.addEventListener('click', closeLocationPicker);

  useCurrentLocationButton?.addEventListener('click', () => {
    if (!navigator.geolocation) {
      if (locationPickerHelp) {
        locationPickerHelp.textContent = '브라우저에서 위치 정보를 지원하지 않습니다.';
      }
      return;
    }

    navigator.geolocation.getCurrentPosition(
      (position) => {
        openLocationPicker();
        setPickedLocation(position.coords.latitude, position.coords.longitude);
      },
      () => {
        if (locationPickerHelp) {
          locationPickerHelp.textContent = '현재 위치를 가져오지 못했습니다. 지도를 직접 클릭해 주세요.';
        }
      }
    );
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const currentForm = e.target as HTMLFormElement;
    const formData = new FormData(currentForm);

    const data = {
      name: formData.get('name'),
      address: formData.get('address'),
      lat: formData.get('lat') || 37.5 + (Math.random() * 0.2 - 0.1),
      lng: formData.get('lng') || 126.9 + (Math.random() * 0.2 - 0.1),
      category: formData.get('category'),
      menuName: formData.get('menuName'),
      menuPrice: formData.get('menuPrice'),
      description: formData.get('description') || '나만의 찐 맛집이에요!',
      phone: formData.get('phone'),
    };

    const places = JSON.parse(localStorage.getItem('user_places') || '[]');
    const newPlace = {
      id: `user_${Date.now()}`,
      ...data,
      rating: 0,
      reviewCount: 0,
      status: 'pending',
      createdAt: new Date().toISOString(),
      reviews: [],
    };

    places.push(newPlace);
    localStorage.setItem('user_places', JSON.stringify(places));

    currentForm.classList.add('hidden');
    document.getElementById('successMessage')?.classList.remove('hidden');
  });
</script>
