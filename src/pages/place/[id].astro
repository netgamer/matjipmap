---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const places = await getCollection('places');
  return places.map((place) => ({
    params: { id: place.id },
    props: { place },
  }));
}

const { place } = Astro.props;
const siteUrl = 'https://xn--0z2byb398d.com';

const categoryLabels = {
  korean: '한식',
  japanese: '일식',
  chinese: '중식',
  western: '양식',
  bunsik: '분식',
  cafe: '카페',
  other: '기타',
};

const category = categoryLabels[place.data.category];
const categoryKeywords = {
  korean: '한식맛집, 한국맛집, 찐한식',
  japanese: '일식맛집, 초밥, 일본음식',
  chinese: '중식맛집, 짜장면, 탕수육',
  western: '양식맛집, 파스타, 피자',
  bunsik: '분식맛집, 떡볶이, 김밥',
  cafe: '카페, 디저트, 커피',
  other: '맛집, 음식',
};

function isPlaceholderImage(url?: string): boolean {
  if (!url) return true;
  return url.includes('images.unsplash.com') || url.includes('loremflickr.com');
}

const realPhotoUrls = [
  place.data.imageUrl,
  ...(place.data.reviews?.map((review: any) => review.imageUrl) ?? []),
].filter((url, index, list): url is string => Boolean(url) && !isPlaceholderImage(url) && list.indexOf(url) === index);

const mainImage = realPhotoUrls[0];
const galleryImages = realPhotoUrls.slice(1, 4);

const pageDescription = `${place.data.name} - ${place.data.address} 주변의 찐맛집! ${place.data.description || `${place.data.name}에서 직접 검증한 로컬 맛집입니다.`} 별점 ${place.data.rating?.toFixed(1) || '?'}/5. 맛집맵에서 확인하세요!`;
const ogImageUrl = mainImage || '/og-image.png';
---

<Layout 
  title={`${place.data.name} - 맛집맵`}
  description={pageDescription}
  ogImage={ogImageUrl}
>
  <div class="mm-shell">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Restaurant",
    "name": place.data.name,
    "image": ogImageUrl,
    "url": `${siteUrl}/place/${place.id}`,
    "description": pageDescription,
    "keywords": `${place.data.name}, ${categoryKeywords[place.data.category]}, 맛집맵, 거지맵 대체`,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": place.data.address,
      "addressLocality": "부산",
      "addressRegion": "경상남도",
      "postalCode": "",
      "addressCountry": "KR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": place.data.lat,
      "longitude": place.data.lng
    },
    "aggregateRating": place.data.rating ? {
      "@type": "AggregateRating",
      "ratingValue": place.data.rating.toFixed(1),
      "reviewCount": place.data.reviewCount || 0
    } : undefined,
    "servesCuisine": category,
    "priceRange": "₩₩",
    "openingHoursSpecification": [],
    "menu": place.data.menus?.map((m: any) => ({
      "@type": "MenuItem",
      "name": m.name,
      "price": m.price.toLocaleString()
    })),
    "review": place.data.reviews?.map((r: any) => ({
      "@type": "Review",
      "author": {
        "@type": "Person",
        "name": r.nickname
      },
      "reviewRating": {
        "@type": "Rating",
        "ratingValue": r.rating
      },
      "reviewBody": r.content,
      "datePublished": r.date
    })),
    "isBasedOn": place.data.reporter ? {
      "@type": "Person",
      "name": place.data.reporter,
      "description": "맛집맵 추천인"
    } : undefined
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "홈",
        "item": siteUrl
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "로컬 맛집",
        "item": siteUrl
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": place.data.name,
        "item": `${siteUrl}/place/${place.id}`
      }
    ]
  })} />
  <SiteHeader active="list" />

  <main class="mm-container py-8 lg:py-10">
    <div class="mm-card overflow-hidden rounded-2xl">
      <div id="map" class="w-full h-64"></div>
      
      <div class="p-4">
        {mainImage ? (
          <div class="grid grid-cols-4 gap-2">
            <div class={galleryImages.length > 0 ? 'col-span-2 row-span-2' : 'col-span-4'}>
              <img 
                src={mainImage} 
                alt={place.data.name}
                class="w-full h-full max-h-[520px] object-cover rounded-lg"
                loading="eager"
              />
            </div>
            {galleryImages.map((img, i) => (
              <div>
                <img 
                  src={img} 
                  alt={`${place.data.name} ${i + 2}`}
                  class="w-full h-full object-cover rounded-lg"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        ) : (
          <div class="rounded-xl border border-dashed border-orange-200 bg-gradient-to-br from-orange-50 to-amber-50 px-6 py-12 text-center text-gray-600">
            <p class="text-sm font-semibold text-orange-700">실제 매장 사진 준비 중</p>
            <p class="mt-2 text-sm">지금은 임시 스톡 이미지를 숨겼습니다. 실제 사진이 등록되면 여기서 바로 노출됩니다.</p>
          </div>
        )}
      </div>
      
      <div class="p-6">
        <div class="flex items-start justify-between mb-4">
          <div>
            <div class="flex items-center gap-3 mb-2">
              <h1 class={`text-2xl font-bold ${place.data.status === 'eliminated' ? 'text-gray-500 line-through' : 'text-gray-900'}`}>{place.data.name}</h1>
              {place.data.status === 'eliminated' ? (
                <span class="px-3 py-1 rounded-full text-sm font-medium bg-gray-200 text-gray-500">
                  탈락
                </span>
              ) : (
                <span class="px-3 py-1 rounded-full text-sm font-medium bg-gradient-to-r from-orange-500 to-red-500 text-white">
                  찐맛집
                </span>
              )}
            </div>
            <p class="text-gray-600">{place.data.address}</p>
          </div>
        </div>

        {place.data.reporter && place.data.reporterId && (
          <a href={`/user/${place.data.reporterId}`} class="block bg-orange-50 rounded-lg p-4 mb-6 hover:bg-orange-100 transition">
            <p class="text-sm text-gray-600 mb-1">추천인</p>
            <div class="flex items-center gap-2">
              <span class="text-lg">👤</span>
              <span class="font-semibold text-gray-900">{place.data.reporter}</span>
              {place.data.reporterRegion && (
                <span class="text-gray-500">({place.data.reporterRegion})</span>
              )}
            </div>
            {place.data.visitedAt && (
              <p class="text-xs text-gray-500 mt-2">
                마지막 방문: {place.data.visitedAt}
              </p>
            )}
          </a>
        )}

        <div class="flex items-center gap-4 mb-6">
          <span class="px-3 py-1 bg-orange-100 text-orange-700 rounded-full text-sm">
            {category}
          </span>
          {place.data.rating && (
            <div class="flex items-center gap-1">
              <span class={place.data.rating < 3 ? 'text-gray-400' : 'text-yellow-500'}>★</span>
              <span class={`font-semibold ${place.data.rating < 3 ? 'text-gray-400' : ''}`}>{place.data.rating.toFixed(1)}</span>
              <span class="text-gray-500">({place.data.reviewCount || 0}명)</span>
            </div>
          )}
        </div>

        {place.data.status === 'eliminated' && (
          <div class="bg-gray-100 border border-gray-300 rounded-lg p-4 mb-6">
            <p class="text-gray-600 text-center">
              이 맛집은 평균 별점이 낮아 탈락했습니다.<br/>
              <span class="text-sm">리뷰를 남기면 다시 순위에 올릴 수 있습니다!</span>
            </p>
          </div>
        )}

        {place.data.description && (
          <section class="mb-6">
            <h2 class="font-semibold text-gray-800 mb-2">💬 추천 이유</h2>
            <p class="text-gray-600 bg-gray-50 rounded-lg p-4 italic">
              "{place.data.description}"
            </p>
          </section>
        )}

        {place.data.reviews && place.data.reviews.length > 0 && (
          <section class="mb-6">
            <h2 class="font-semibold text-gray-800 mb-3">📝 찐 리뷰 ({place.data.reviews.length}개)</h2>
            <div class="space-y-4">
              {place.data.reviews.map((review: any, index: number) => (
                <div class="bg-gray-50 rounded-lg p-4">
                  <div class="flex items-center justify-between mb-2">
                    <a href={`/user/${review.userId}`} class="flex items-center gap-2 hover:text-orange-600">
                      <span class="font-semibold text-gray-900">{review.nickname}</span>
                      <span class="text-xs text-gray-500">@{review.userId}</span>
                    </a>
                    <span class="text-xs text-gray-500">{review.date}</span>
                  </div>
                  <div class="flex items-center gap-1 mb-2">
                    {[...Array(5)].map((_, i) => (
                      <span class={`text-lg ${i < review.rating ? 'text-yellow-500' : 'text-gray-300'}`}>★</span>
                    ))}
                  </div>
                  {review.imageUrl && !isPlaceholderImage(review.imageUrl) && (
                    <div class="mb-2">
                      <img 
                        src={review.imageUrl} 
                        alt="리뷰 사진"
                        class="w-32 h-32 object-cover rounded-lg"
                        loading="lazy"
                      />
                    </div>
                  )}
                  <p class="text-gray-700">{review.content}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        <section class="mb-6">
          <h2 class="font-semibold text-gray-800 mb-3">🍽️ 대표 메뉴</h2>
          <div class="space-y-2">
            {place.data.menus.map((menu: any) => (
              <div class="flex justify-between items-center py-3 px-4 bg-gray-50 rounded-lg">
                <span class="text-gray-700 font-medium">{menu.name}</span>
                <span class="font-bold text-orange-600">{menu.price.toLocaleString()}원</span>
              </div>
            ))}
          </div>
        </section>

        <section class="mb-6">
          <h2 class="font-semibold text-gray-800 mb-3">📝 리뷰 작성</h2>
          <form class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">별점</label>
              <div class="flex gap-2">
                {[1, 2, 3, 4, 5].map((star) => (
                  <button type="button" class="text-3xl text-gray-300 hover:text-yellow-500 transition">★</button>
                ))}
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">리뷰</label>
              <textarea 
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500"
                rows="4"
                placeholder="이 맛집은 어떤 점이 좋았나요?"
              ></textarea>
            </div>
            <button 
              type="submit"
              class="w-full bg-gradient-to-r from-orange-500 to-red-500 text-white py-3 px-4 rounded-lg font-medium hover:opacity-90 transition"
            >
              리뷰 등록
            </button>
          </form>
        </section>
      </div>
    </div>
  </main>
  </div>
</Layout>

<script define:vars={{ lat: place.data.lat, lng: place.data.lng }}>
  function initPlaceMap() {
    if (typeof naver === 'undefined') {
      setTimeout(initPlaceMap, 100);
      return;
    }
    
    const map = new naver.maps.Map('map', {
      center: new naver.maps.LatLng(lat, lng),
      zoom: 15,
    });
    new naver.maps.Marker({
      position: new naver.maps.LatLng(lat, lng),
      map,
    });
  }
  
  initPlaceMap();
</script>
