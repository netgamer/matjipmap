---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const places = await getCollection('places');
  return places.map((place) => ({
    params: { id: place.id },
    props: { place },
  }));
}

const { place } = Astro.props;

const categoryLabels = {
  korean: '한식',
  japanese: '일식',
  chinese: '중식',
  western: '양식',
  bunsik: '분식',
  cafe: '카페',
  other: '기타',
};

const category = categoryLabels[place.data.category];
---

<Layout title={`${place.data.name} - 맛집맵`}>
  <header class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="text-xl font-bold text-orange-600 flex items-center gap-2">
        <span>🍽️</span>
        맛집맵
      </a>
      <a href="/" class="text-gray-600 hover:text-orange-600">← 맛집 목록</a>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 py-6">
    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
      <div id="map" class="w-full h-64"></div>
      
      <div class="p-6">
        <div class="flex items-start justify-between mb-4">
          <div>
            <div class="flex items-center gap-3 mb-2">
              <h1 class="text-2xl font-bold text-gray-900">{place.data.name}</h1>
              <span class="px-3 py-1 rounded-full text-sm font-medium bg-gradient-to-r from-orange-500 to-red-500 text-white">
                🏆 찐맛집
              </span>
            </div>
            <p class="text-gray-600">{place.data.address}</p>
          </div>
        </div>

        {place.data.reporter && (
          <div class="bg-orange-50 rounded-lg p-4 mb-6">
            <p class="text-sm text-gray-600 mb-1">추천인</p>
            <div class="flex items-center gap-2">
              <span class="text-lg">👤</span>
              <span class="font-semibold text-gray-900">{place.data.reporter}</span>
              {place.data.reporterRegion && (
                <span class="text-gray-500">({place.data.reporterRegion})</span>
              )}
            </div>
            {place.data.visitedAt && (
              <p class="text-xs text-gray-500 mt-2">
                마지막 방문: {place.data.visitedAt}
              </p>
            )}
          </div>
        )}

        <div class="flex items-center gap-4 mb-6">
          <span class="px-3 py-1 bg-orange-100 text-orange-700 rounded-full text-sm">
            {category}
          </span>
          {place.data.rating && (
            <div class="flex items-center gap-1">
              <span class="text-yellow-500">★</span>
              <span class="font-semibold">{place.data.rating.toFixed(1)}</span>
              <span class="text-gray-500">({place.data.reviewCount || 0}명)</span>
            </div>
          )}
        </div>

        {place.data.description && (
          <section class="mb-6">
            <h2 class="font-semibold text-gray-800 mb-2">💬 추천 이유</h2>
            <p class="text-gray-600 bg-gray-50 rounded-lg p-4 italic">
              "{place.data.description}"
            </p>
          </section>
        )}

        <section class="mb-6">
          <h2 class="font-semibold text-gray-800 mb-3">🍽️ 대표 메뉴</h2>
          <div class="space-y-2">
            {place.data.menus.map((menu: any) => (
              <div class="flex justify-between items-center py-3 px-4 bg-gray-50 rounded-lg">
                <span class="text-gray-700 font-medium">{menu.name}</span>
                <span class="font-bold text-orange-600">{menu.price.toLocaleString()}원</span>
              </div>
            ))}
          </div>
        </section>

        <section class="mb-6">
          <h2 class="font-semibold text-gray-800 mb-3">📝 리뷰 작성</h2>
          <form class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">별점</label>
              <div class="flex gap-2">
                {[1, 2, 3, 4, 5].map((star) => (
                  <button type="button" class="text-3xl text-gray-300 hover:text-yellow-500 transition">★</button>
                ))}
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">리뷰</label>
              <textarea 
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500"
                rows="4"
                placeholder="이 맛집은 어떤 점이 좋았나요?"
              ></textarea>
            </div>
            <button 
              type="submit"
              class="w-full bg-gradient-to-r from-orange-500 to-red-500 text-white py-3 px-4 rounded-lg font-medium hover:opacity-90 transition"
            >
              리뷰 등록
            </button>
          </form>
        </section>
      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ lat: place.data.lat, lng: place.data.lng }}>
  function initPlaceMap() {
    if (typeof naver === 'undefined') {
      setTimeout(initPlaceMap, 100);
      return;
    }
    
    const map = new naver.maps.Map('map', {
      center: new naver.maps.LatLng(lat, lng),
      zoom: 15,
    });
    new naver.maps.Marker({
      position: new naver.maps.LatLng(lat, lng),
      map,
    });
  }
  
  initPlaceMap();
</script>
