---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const places = await getCollection('places');
  const userPlaces: { [key: string]: typeof places } = {};
  
  places.forEach((place) => {
    if (place.data.reporterId) {
      if (!userPlaces[place.data.reporterId]) {
        userPlaces[place.data.reporterId] = [];
      }
      userPlaces[place.data.reporterId].push(place);
    }
  });
  
  return Object.entries(userPlaces).map(([userId, userPlaceList]) => ({
    params: { id: userId },
    props: { userId, places: userPlaceList },
  }));
}

const { userId, places } = Astro.props;

const categoryLabels = {
  korean: '한식',
  japanese: '일식',
  chinese: '중식',
  western: '양식',
  bunsik: '분식',
  cafe: '카페',
  other: '기타',
};

const statusLabels = {
  verified: { text: '🏆 찐맛집', class: 'bg-gradient-to-r from-orange-500 to-red-500 text-white' },
  pending: { text: '⏳ 검토중', class: 'bg-yellow-100 text-yellow-700' },
  eliminated: { text: '❌ 탈락', class: 'bg-gray-200 text-gray-500' },
  reviewing: { text: '🔍 조사중', class: 'bg-blue-100 text-blue-700' },
};
---

<Layout title={`${userId}님의 찐맛집 - 맛집맵`}>
  <header class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="text-xl font-bold text-orange-600 flex items-center gap-2">
        <span>🍽️</span>
        맛집맵
      </a>
      <a href="/" class="text-gray-600 hover:text-orange-600">← 맛집 목록</a>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 py-6">
    <div class="bg-white rounded-xl shadow-sm overflow-hidden mb-6">
      <div class="p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-16 h-16 bg-gradient-to-br from-orange-400 to-red-500 rounded-full flex items-center justify-center text-white text-2xl font-bold">
            {userId.slice(-2)}
          </div>
          <div>
            <h1 class="text-2xl font-bold text-gray-900">{userId}</h1>
            <p class="text-gray-500"> 찐맛집 {places.length}개 추천</p>
          </div>
        </div>
      </div>
    </div>

    <h2 class="text-xl font-bold text-gray-800 mb-4">📍 추천한 찐맛집</h2>
    
    <div class="grid gap-4 md:grid-cols-2">
      {places.map((place) => {
        const status = statusLabels[place.data.status];
        const category = categoryLabels[place.data.category];
        return (
          <a href={`/place/${place.id}`} class="bg-white rounded-xl shadow-sm overflow-hidden hover:shadow-md transition block">
            <div class="p-4">
              <div class="flex items-start justify-between mb-2">
                <h3 class="font-bold text-gray-900 text-lg">{place.data.name}</h3>
                <span class={`px-2 py-1 rounded-full text-xs font-medium ${status.class}`}>
                  {status.text}
                </span>
              </div>
              <p class="text-gray-500 text-sm mb-3">{place.data.address}</p>
              <div class="flex items-center gap-3">
                <span class="px-2 py-1 bg-orange-100 text-orange-700 rounded-full text-xs">
                  {category}
                </span>
                {place.data.rating && (
                  <div class="flex items-center gap-1 text-sm">
                    <span class="text-yellow-500">★</span>
                    <span class="font-medium">{place.data.rating.toFixed(1)}</span>
                  </div>
                )}
              </div>
            </div>
          </a>
        );
      })}
    </div>

    {places.length === 0 && (
      <div class="text-center py-12 text-gray-500">
        <p class="text-4xl mb-4">🔍</p>
        <p>아직 추천한 맛집이 없습니다.</p>
      </div>
    )}
  </main>
</Layout>
